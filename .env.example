# Copy this file to .env and fill in your values
# NEVER share your .env file or commit it to GitHub

# Get this from MongoDB Atlas (we'll set this up together)
MONGODB_URI=mongodb+srv://youruser:yourpassword@cluster0.xxxxx.mongodb.net/decisiondebt

# Make this a long random string — it's used to sign login tokens
# You can generate one at: https://randomkeygen.com
JWT_SECRET=replace_this_with_a_long_random_string_at_least_32_chars

# Port the server runs on (Render sets this automatically)
PORT=5000
